// GOOD: Generated API integration with TypeScript

// Generated API types (from OpenAPI/Orval)
import type {
  MessageOutputModal,
  MessageDetailViewResponseResponse,
  GetMessagesParams,
  CreateMessageRequest,
  ApiResponse
} from '@/generated/api/model'

import {
  getMessages,
  getMessageDetailView,
  createMessage,
  type GetMessagesResult,
  type CreateMessageResult
} from '@/generated/api/messages/messages'

// Service layer with proper typing
export class MessageService {
  static async fetchMessages(params: GetMessagesParams): Promise<MessageOutputModal[]> {
    try {
      const response: GetMessagesResult = await getMessages(params)
      return response.data?.content ?? []
    } catch (error) {
      throw new MessageServiceError('Failed to fetch messages', error)
    }
  }

  static async fetchMessageDetail(id: string): Promise<MessageDetailViewResponseResponse> {
    try {
      const response = await getMessageDetailView<AxiosResponse<MessageDetailViewResponseResponse>>(id)
      return response.data
    } catch (error) {
      if (error.response?.status === 404) {
        throw new NotFoundError(`Message with ID ${id} not found`)
      }
      throw new MessageServiceError('Failed to fetch message detail', error)
    }
  }

  static async createMessage(data: CreateMessageRequest): Promise<MessageOutputModal> {
    try {
      const response: CreateMessageResult = await createMessage(data)
      return response.data
    } catch (error) {
      throw new MessageServiceError('Failed to create message', error)
    }
  }
}

// Custom error classes
class MessageServiceError extends Error {
  constructor(message: string, public readonly originalError?: unknown) {
    super(message)
    this.name = 'MessageServiceError'
  }
}

class NotFoundError extends MessageServiceError {
  constructor(message: string) {
    super(message)
    this.name = 'NotFoundError'
  }
}

// Composable for API integration
export function useMessageApi() {
  const loading = ref(false)
  const error = ref<Error | null>(null)

  const fetchMessages = async (params: GetMessagesParams): Promise<MessageOutputModal[]> => {
    loading.value = true
    error.value = null

    try {
      return await MessageService.fetchMessages(params)
    } catch (err) {
      error.value = err instanceof Error ? err : new Error(String(err))
      throw error.value
    } finally {
      loading.value = false
    }
  }

  const fetchMessageDetail = async (id: string): Promise<MessageDetailViewResponseResponse> => {
    loading.value = true
    error.value = null

    try {
      return await MessageService.fetchMessageDetail(id)
    } catch (err) {
      error.value = err instanceof Error ? err : new Error(String(err))
      throw error.value
    } finally {
      loading.value = false
    }
  }

  return {
    loading: readonly(loading),
    error: readonly(error),
    fetchMessages,
    fetchMessageDetail
  }
}

// Advanced utility types
type ExtractApiResponse<T> = T extends Promise<infer U> ? U : never
type MessageApiResponse = ExtractApiResponse<ReturnType<typeof MessageService.fetchMessages>>

// Type-safe configuration
interface ApiConfig {
  readonly baseUrl: string
  readonly timeout: number
  readonly retries: number
}

const apiConfig: ApiConfig = {
  baseUrl: '/api',
  timeout: 10000,
  retries: 3
}
```
