<!-- GOOD: SSR-aware component with client-only functionality -->
<script setup lang="ts">
// SSR-safe state using useState
const counter = useState('counter', () => 0)

// Client-only code in onMounted
onMounted(() => {
  // Safe to use browser APIs here
  const savedValue = localStorage.getItem('counter')
  if (savedValue) {
    counter.value = parseInt(savedValue, 10)
  }
})

// Watch with cleanup
const stopWatch = watch(counter, (newValue) => {
  // Only runs on client after hydration
  if (import.meta.client) {
    localStorage.setItem('counter', String(newValue))
  }
})

onBeforeUnmount(() => {
  stopWatch()
})
</script>

<template>
  <div>
    <p>Counter: {{ counter }}</p>
    <button @click="counter++">Increment</button>

    <!-- Client-only component -->
    <ClientOnly>
      <ThirdPartyWidget />
      <template #fallback>
        <p>Loading widget...</p>
      </template>
    </ClientOnly>
  </div>
</template>
