    }
  }

  static async fetchMessageDetail(id: string): Promise<MessageDetailViewResponseResponse> {
    try {
      const response = await getMessageDetailView<AxiosResponse<MessageDetailViewResponseResponse>>(id)
      return response.data
    } catch (error) {
      if (error.response?.status === 404) {
        throw new NotFoundError(`Message with ID ${id} not found`)
      }
      throw new MessageServiceError('Failed to fetch message detail', error)
    }
  }

  static async createMessage(data: CreateMessageRequest): Promise<MessageOutputModal> {
    try {
      const response: CreateMessageResult = await createMessage(data)
      return response.data
    } catch (error) {
      throw new MessageServiceError('Failed to create message', error)
    }
  }
}

// Custom error classes
class MessageServiceError extends Error {
  constructor(message: string, public readonly originalError?: unknown) {
    super(message)
    this.name = 'MessageServiceError'
  }
}

class NotFoundError extends MessageServiceError {
  constructor(message: string) {
    super(message)
    this.name = 'NotFoundError'
  }
}

// Composable for API integration
export function useMessageApi() {
  const loading = ref(false)
  const error = ref<Error | null>(null)

  async function fetchMessages(params: GetMessagesParams): Promise<MessageOutputModal[]> {
    loading.value = true
    error.value = null

    try {
      return await MessageService.fetchMessages(params)
    } catch (err) {
      error.value = err instanceof Error ? err : new Error(String(err))
      throw error.value
    } finally {
      loading.value = false
    }
  }

  async function fetchMessageDetail(id: string): Promise<MessageDetailViewResponseResponse> {
    loading.value = true
    error.value = null

    try {
      return await MessageService.fetchMessageDetail(id)
    } catch (err) {
      error.value = err instanceof Error ? err : new Error(String(err))
      throw error.value
    } finally {
      loading.value = false
    }
  }

  return {
    loading: readonly(loading),
    error: readonly(error),
    fetchMessages,
    fetchMessageDetail
  }
}

// Advanced utility types
