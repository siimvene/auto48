// GOOD: Advanced Pinia store patterns with TypeScript

// Composition API style store (modern approach)
export const useMessageStore = defineStore('messages', () => {
  // State with proper typing
  const messages = ref<MessageOutputModal[]>([])
  const loading = ref(false)
  const error = ref<Error | null>(null)

  // Persistent state with VueUse
  const selectedPageSize = useSessionStorage<number>('selectedPageSize', 50)
  const filters = useSessionStorage<MessageFilters>('messagesFilters', {
    status: [MessageStatus.REGISTERED, MessageStatus.IN_PROGRESS],
    direction: [],
    priority: []
  })

  // Computed values
  const filteredMessages = computed(() =>
    messages.value.filter(msg => matchesFilters(msg, filters.value))
  )

  const totalCount = computed(() => messages.value.length)

  // Actions with proper error handling
  async function fetchMessages(params: GetMessagesParams): Promise<void> {
    loading.value = true
    error.value = null

    try {
      const response = await getMessages(params)
      messages.value = response.data?.content ?? []
    } catch (err) {
      error.value = err instanceof Error ? err : new Error(String(err))
      throw error.value
    } finally {
      loading.value = false
    }
  }

  function setFilters(newFilters: Partial<MessageFilters>) {
    filters.value = { ...filters.value, ...newFilters }
  }

  // Reset function
  function reset() {
    messages.value = []
    loading.value = false
    error.value = null
  }

  return {
    // State
    messages: readonly(messages),
    loading: readonly(loading),
    error: readonly(error),
    selectedPageSize,
    filters,

    // Computed
    filteredMessages,
    totalCount,

    // Actions
    fetchMessages,
    setFilters,
    reset
  }
})

// Options API style store (traditional approach)
export const useUserStore = defineStore('users', {
  state: (): UserStoreState => ({
    users: [],
    currentUser: null,
    loading: false,
    // Persistent state with VueUse
    preferences: useLocalStorage<UserPreferences>('userPreferences', {
      theme: 'light',
      language: 'en'
    })
  }),

  getters: {
    isAuthenticated: (state): boolean => state.currentUser !== null,

    userById: (state) => (id: string): User | undefined =>
      state.users.find(user => user.id === id),

    totalUsers: (state): number => state.users.length
  },

  actions: {
    async fetchUser(id: string): Promise<User> {
      this.loading = true

      try {
        const response = await getUserById(id)
        const user = response.data

        // Update users array
        const index = this.users.findIndex(u => u.id === id)
        if (index !== -1) {
          this.users[index] = user
        } else {
          this.users.push(user)
        }

        return user
      } catch (error) {
        throw new Error(`Failed to fetch user: ${error.message}`)
      } finally {
        this.loading = false
      }
    },

    setCurrentUser(user: User | null) {
      this.currentUser = user
    },

    updatePreferences(newPrefs: Partial<UserPreferences>) {
      this.preferences = { ...this.preferences, ...newPrefs }
    }
  }
})

// Store interfaces
interface MessageFilters {
  status: MessageStatus[]
  direction: MessageDirection[]
  priority: MessagePriority[]
  search?: string
}

interface UserStoreState {
  users: User[]
  currentUser: User | null
  loading: boolean
  preferences: Ref<UserPreferences>
}

interface UserPreferences {
  theme: 'light' | 'dark'
  language: string
}
