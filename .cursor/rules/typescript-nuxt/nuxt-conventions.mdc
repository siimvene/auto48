import type { MessageFilters } from '@/stores/message.store'
import { useMessageStore } from '@/stores/message.store'
import { storeToRefs } from 'pinia'

// Component instance typing
type LitepickerType = InstanceType<typeof Litepicker>
type TomSelectType = InstanceType<typeof TomSelect>
type ButtonType = InstanceType<typeof Button>

// Extract component props typing
type ExtractProps<T> = InstanceType<T>['$props']
type LitepickerProps = ExtractProps<typeof Litepicker>

// Props interface
interface MessageFilterProps {
  initialFilters?: Partial<MessageFilters>
  disabled?: boolean
}

const props = withDefaults(defineProps<MessageFilterProps>(), {
  disabled: false
})

// Emits interface
interface MessageFilterEmits {
  (e: 'filter-applied', filters: MessageFilters): void
  (e: 'filter-reset'): void
}

const emit = defineEmits<MessageFilterEmits>()

// Template refs with proper typing
const datePickerRef = useTemplateRef<LitepickerType>('datePickerRef')
const statusSelectRef = useTemplateRef<TomSelectType>('statusSelectRef')
const submitButtonRef = useTemplateRef<ButtonType>('submitButtonRef')

// Store integration
const messageStore = useMessageStore()
const { filters } = storeToRefs(messageStore)

// VueUse composables
const isOnline = useOnline()
const windowSize = useWindowSize()
const { copy, copied } = useClipboard()

// Reactive state
const isSubmitting = ref(false)
const formData = ref<MessageFilters>({
  status: [],
  direction: [],
  priority: [],
  dateRange: [],
  search: '',
  ...props.initialFilters
})

// Computed with proper typing
const isFormValid = computed((): boolean => {
  return formData.value.status.length > 0 ||
         formData.value.search?.trim() !== ''
})

const datePickerOptions = computed((): LitepickerProps['options'] => ({
  autoApply: true,
  singleMode: false,
  numberOfColumns: 2,
  format: 'YYYY-MM-DD'
}))

// Methods with template ref access
async function applyFilter(): Promise<void> {
  if (!isFormValid.value || props.disabled) return

  isSubmitting.value = true

  try {
    // Access template ref methods
    const dateRange = datePickerRef.value?.getDates()
    const selectedStatuses = statusSelectRef.value?.getSelected()

    const filterData: MessageFilters = {
      ...formData.value,
      dateRange: dateRange || [],
      status: selectedStatuses || []
    }

    await messageStore.setFilters(filterData)
    emit('filter-applied', filterData)

    // Focus management
    submitButtonRef.value?.$el.blur()
  } catch (error) {
    console.error('Failed to apply filter:', error)
  } finally {
    isSubmitting.value = false
  }
}

function resetFilter(): void {
  // Reset form data
  formData.value = {
    status: [],
    direction: [],
    priority: [],
    dateRange: [],
    search: ''
  }

  // Reset component refs
  datePickerRef.value?.reset()
  statusSelectRef.value?.clear()

  emit('filter-reset')
}

// Lifecycle with ref access
onMounted(() => {
  // Initialize component refs after mount
  if (datePickerRef.value) {
    datePickerRef.value.focus()
  }
})

// Watch with typing
watch(() => props.initialFilters, (newFilters) => {
  if (newFilters) {
    formData.value = { ...formData.value, ...newFilters }
  }
}, { deep: true })

// Expose methods for parent access
defineExpose({
  applyFilter,
  resetFilter,
  focusDatePicker: () => datePickerRef.value?.focus(),
  getFormData: () => formData.value
})
</script>
