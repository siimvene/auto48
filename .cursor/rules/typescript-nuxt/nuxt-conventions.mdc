<!-- GOOD: Proper Vue 3 + Nuxt component structure -->
<script setup lang="ts">
// Type definitions
type UserProfile = {
  id: string
  name: string
  email: string
  avatar?: string
}

// Props with TypeScript interface and validation
type Props = {
  userId: string
  readonly?: boolean
}

const props = withDefaults(defineProps<Props>(), {
  readonly: false
})

// Emits with TypeScript interface
type Emits = {
  (e: 'profile-updated', profile: UserProfile): void
  (e: 'profile-deleted'): void
}

const emit = defineEmits<Emits>()

// Composables (auto-imported by Nuxt)
const userStore = useUserStore()
const loggingService = useLoggingService()
const { t } = useI18n()

// Nuxt data fetching with proper error handling
const { data: userData, error, pending } = await useFetch<UserProfile>(
  () => `/api/users/${props.userId}`,
  {
    key: `user-${props.userId}`,
    getCachedData: (key, nuxtApp) => nuxtApp.payload.data[key]
  }
)

// Reactive state with proper typing
const isLoading = ref(false)
const user = computed(() => userData.value ?? userStore.getUser(props.userId))
const canEdit = computed(() => !props.readonly && user.value?.canEdit)

// Methods with proper error handling
async function saveProfile(profileData: Partial<UserProfile>) {
  if (!canEdit.value) return

  isLoading.value = true

  try {
    const updatedProfile = await userStore.updateProfile(props.userId, profileData)

    loggingService.log('info', 'User profile saved', {
      eventType: 'USER_PROFILE_SAVED',
      component: 'UserProfile',
      userId: props.userId,
      updatedFields: Object.keys(profileData)
    })

    emit('profile-updated', updatedProfile)
  } catch (error) {
    loggingService.log('error', 'Failed to save user profile', {
      eventType: 'USER_PROFILE_SAVE_ERROR',
      component: 'UserProfile',
      userId: props.userId,
      error: { message: error.message }
    })

    throw error // Re-throw for component to handle
  } finally {
    isLoading.value = false
  }
}

// Lifecycle with proper cleanup
onMounted(() => {
  loggingService.log('debug', 'UserProfile component mounted', {
    eventType: 'COMPONENT_MOUNTED',
    component: 'UserProfile',
    userId: props.userId
  })
})

onUnmounted(() => {
  loggingService.log('debug', 'UserProfile component unmounted', {
    eventType: 'COMPONENT_UNMOUNTED',
    component: 'UserProfile',
    userId: props.userId
  })
})

// Expose methods for parent components
defineExpose({
  saveProfile
})
</script>

<template>
  <div class="flex flex-col p-8 user-profile">
    <!-- Loading state -->
    <div v-if="pending">Loading...</div>

    <!-- Error state -->
    <div v-else-if="error">
      Error loading user: {{ error.message }}
    </div>

    <!-- Content -->
    <template v-else>
      <h1>{{ user?.name }}</h1>
      <button @click="saveProfile" :disabled="isLoading">
        {{ isLoading ? 'Saving...' : 'Save Profile' }}
      </button>
    </template>
  </div>
</template>

<style scoped>
.user-profile {
  /* Use scoped styles for complex styling not suitable for utility classes */
}
</style>
```
</example>

