# Copy to .env for local development. All vars are prefixed AUTO48_.
AUTO48_ENVIRONMENT=local
AUTO48_DEBUG=true

# Local dev defaults to sqlite (zero config). For real environments use Postgres:
# AUTO48_DATABASE_URL=postgresql+asyncpg://auto48:CHANGE_ME@localhost:5432/auto48
AUTO48_DATABASE_URL=sqlite+aiosqlite:///./auto48.db

# ------------------------------------------------------------
# Docker Compose local infrastructure (used in later phases).
# Run `docker compose up -d` then copy these overrides into .env.
# ------------------------------------------------------------
# Postgres (PostGIS) — matches the `db` service
# AUTO48_DATABASE_URL=postgresql+asyncpg://auto48:auto48@localhost:5432/auto48

# Redis — matches the `redis` service
# AUTO48_REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage — matches the `minio` service
# AUTO48_S3_ENDPOINT=http://localhost:9000
# AUTO48_S3_ACCESS_KEY=auto48
# AUTO48_S3_SECRET_KEY=auto48secret
# AUTO48_S3_BUCKET=auto48-media
